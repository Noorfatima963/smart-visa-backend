          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", ""]
            }
          }
        },
