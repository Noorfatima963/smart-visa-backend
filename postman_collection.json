              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/documents/definitions/",
              "host": ["{{base_url}}"],
              "path": ["api", "documents", "definitions", ""]
            }
          }
        },
        {
          "name": "Get User Documents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/documents/",
