              "raw": "{\n    \"country_visited\": \"UK\",\n    \"purpose_of_visit\": \"Tourism\",\n    \"visa_type\": \"Tourist Visa\",\n    \"entry_date\": \"2022-05-10\",\n    \"exit_date\": \"2022-05-25\",\n    \"was_visa_rejected\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/profile/travel-history/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", "travel-history", ""]
            }
          }
        },
        {
          "name": "Update Financial Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"primary_sponsor\": \"Parents\",\n    \"annual_family_income\": 50000.00,\n    \"available_savings\": 20000.00\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/profile/financial/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", "financial", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Get Document Definitions",
          "request": {
            "method": "GET",
