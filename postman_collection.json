        },
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "definition_slug",
                  "value": "passport",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/documents/",
              "host": ["{{base_url}}"],
              "path": ["api", "documents", ""]
            }
          }
        }
      ]
    },
    {
